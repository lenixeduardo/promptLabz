# Supabase Credentials
# Get these from Supabase Dashboard > Project Settings > API

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
APP_URL=https://your-app-domain.com
APP_NAME=PromptLabzz
RESEND_FROM_EMAIL=no-reply@your-app-domain.com
RESEND_API_KEY=your_resend_api_key_here
SEND_EMAIL_HOOK_SECRET=v1,whsec_your_hook_secret_here

# Optional for server-side smoke checks and CI.
# Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
