# ──────────────────────────────────────────────────────────────────────────
# PromptLabz — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file with real credentials.
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase (required for auth + database) ───────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App Metadata (used in Edge Functions) ─────────────────────────────────
APP_URL=https://your-app-domain.com
APP_NAME=PromptLabz
RESEND_FROM_EMAIL=no-reply@your-app-domain.com
RESEND_API_KEY=your_resend_api_key_here
SEND_EMAIL_HOOK_SECRET=v1,whsec_your_hook_secret_here

# ── PostHog (product analytics — optional) ────────────────────────────────
# Get your project API key at: https://us.posthog.com/settings/project
# Leave empty to disable tracking completely.
VITE_POSTHOG_KEY=phc_your_project_api_key_here
# Optional — default is https://us.i.posthog.com
# For EU cloud users: https://eu.i.posthog.com
VITE_POSTHOG_HOST=

# ── Sentry (optional — error monitoring & source maps) ───────────────────
# VITE_SENTRY_DSN (public — goes to the browser): frontend error tracking.
# Get it at: https://sentry.io → Project → Client Keys (DSN)
# Leave empty to disable Sentry completely.
VITE_SENTRY_DSN=
# SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN are used at build time
# to upload source maps so stack traces show real code, not minified.
#   ORG:     Settings > General Settings > Organization slug
#   PROJECT: Settings > Projects > your-project > Project slug
#   TOKEN:   Settings > Developer Settings > Auth Tokens → Create New Token
#            (needs project:read, project:releases, org:read permissions)
# These variables are NOT exposed to the browser — set them in CI/CD or
# in your local shell when running pnpm build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Supabase Service Role Key (server-side only, NEVER expose to browser) ─
# Used by smoke tests and server-side scripts only.
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Daily Tech News routine ────────────────────────────────────────────────
# Random secret used to authenticate calls to the daily-tech-news Edge Function.
# Generate with: openssl rand -base64 32
# Set in: Supabase Edge Function secrets AND GitHub Actions secrets.
DAILY_NEWS_SECRET=your_random_secret_here

# ── Anthropic API (server-side only, NEVER expose to browser) ────────────
# Powers the optional "Análise com IA" feature in the Prompt Analyzer
# (Edge Function: supabase/functions/evaluate-prompt). This is a secret —
# it must never be prefixed with VITE_ or referenced from browser code.
# Get your key at: https://console.anthropic.com/settings/keys
# Set it as an Edge Function secret (NOT in .env.local):
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-your-key-here
# Without this secret configured, the evaluate-prompt function returns a
# graceful 503 and the UI falls back to the local heuristic engine.
ANTHROPIC_API_KEY=
