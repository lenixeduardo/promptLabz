{
  "name": "promptlabz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "node -e \"require('fs').rmSync('node_modules/.vite-temp',{recursive:true,force:true})\" && tsc -b && vite build",
    "build:prod": "node -e \"require('fs').rmSync('node_modules/.vite-temp',{recursive:true,force:true})\" && tsc -b && BUILD_MODE=prod vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke:supabase": "node scripts/smoke-supabase.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm smoke:supabase",
    "install-deps": "pnpm install --prefer-offline",
    "clean": "rm -rf node_modules .pnpm-store pnpm-lock.yaml && pnpm store prune",
    "ios:init": "pnpm build && cap add ios",
    "ios:sync": "pnpm build && cap sync ios",
    "ios:open": "cap open ios",
    "ios:build": "pnpm build && cap sync ios && cap build ios"
  },
  "dependencies": {
